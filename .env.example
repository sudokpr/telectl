# Telegram bot token from BotFather.
# Set false to run only local HTTP intake/metrics when Telegram is unavailable.
TELEGRAM_BOT_ENABLED=true
BOT_TOKEN=

# Target Telegram supergroup and topic.
TELEGRAM_CHAT_ID=
TELEGRAM_TOPIC_ID=

# Optional comma-separated Telegram user IDs. Empty means any user in the
# configured chat/topic can trigger commands.
ALLOWED_USER_IDS=

# Command used to start Codex remote control.
CODEX_REMOTE_COMMAND=codex remote-control
# Start Codex remote-control in its own systemd user scope so restarting the
# Telegram bot service does not kill the active Codex session.
CODEX_REMOTE_DETACHED=true

# Working directory for the remote-control process.
CODEX_REMOTE_WORKDIR=.

# Optional fallback env file for TELEGRAM__CHAT_ID-style config.
TELEGRAM_ENV_PATH=

# Image summary topic worker.
IMAGE_SUMMARY_TOPIC_ID=
IMAGE_SUMMARY_MODE=compare
IMAGE_SUMMARY_WORK_DIR=./data/image-summary
IMAGE_SUMMARY_DEBUG_UPDATES=true
IMAGE_SUMMARY_OCR_ENABLED=false
IMAGE_SUMMARY_OCR_COMMAND=tesseract
IMAGE_SUMMARY_OCR_LANG=eng
IMAGE_SUMMARY_OCR_PSM=6
IMAGE_SUMMARY_OCR_LLM_MODEL=llama3.1:8b
IMAGE_SUMMARY_VISION_LLM_MODEL=gemma4:e2b
IMAGE_SUMMARY_VISION_MODELS=minicpm-v:latest
IMAGE_SUMMARY_OLLAMA_URL=http://localhost:11434
IMAGE_SUMMARY_OLLAMA_TIMEOUT_SECONDS=600

# Codex SDK LLM POC. Reuses existing Codex auth and the local Codex app server.
CODEX_LLM_CWD=.
CODEX_LLM_ENABLED=true
CODEX_LLM_MODEL=gpt-5.4-mini
CODEX_LLM_SANDBOX=read_only
CODEX_LLM_EPHEMERAL=true
CODEX_LLM_BASE_INSTRUCTIONS=

# Plain text messages in IMAGE_SUMMARY_TOPIC_ID are converted to memory files.
MEMORY_WORK_DIR=./data/memories
MEMORY_LLM_MODEL=llama3.1:8b
MEMORY_QUERY_MODEL=gemma4:31b-cloud
MEMORY_QUERY_TOP_K=1
MEMORY_QUERY_MAX_CONTEXT_CHARS=14000

# Optional local HTTP endpoint for iOS Shortcuts.
HTTP_INTAKE_ENABLED=false
HTTP_INTAKE_HOST=127.0.0.1
HTTP_INTAKE_PORT=8787
HTTP_INTAKE_TOKEN=
HTTP_INTAKE_NOTIFY_TELEGRAM=true

# Optional Prometheus metrics endpoint. When HTTP intake is enabled, metrics
# are served at /metrics on the intake server. Otherwise a local scrape server
# is started on PROMETHEUS_METRICS_HOST:PROMETHEUS_METRICS_PORT.
PROMETHEUS_METRICS_ENABLED=false
PROMETHEUS_METRICS_HOST=127.0.0.1
PROMETHEUS_METRICS_PORT=8788

# Fuel receipt + odometer workflow.
FUEL_ENABLED=true
FUEL_TOPIC_ID=
FUEL_WORK_DIR=./data/fuel
FUEL_CSV_PATH=./Fuelio_yyyy-MM-dd.csv
# codex uses the Codex SDK config above. Set ollama to use FUEL_MODEL locally.
FUEL_LLM_PROVIDER=codex
FUEL_MODEL=minicpm-v:latest
FUEL_PENDING_WINDOW_SECONDS=90
FUEL_CORRECTION_WINDOW_SECONDS=300
FUEL_CSV_FIELDS=Date,Odo (km),Fuel (l),Full,Price,km/l,latitude,longitude,City,Notes,Missed,TankNumber,FuelType,VolumePrice,StationID,ExcludeDistance,UniqueId,TankCalc,Weather

# OwnTracks daily activity review.
OWNTRACKS_TOPIC_ID=
MQTT_HOST=localhost
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_TOPIC=owntracks/#
OWNTRACKS_LOG_PATH=./data/owntracks/mqtt.log
OWNTRACKS_DERIVED_DIR=./data/owntracks/derived
OWNTRACKS_USER_TAGS_PATH=./data/owntracks/user_tags.json
OWNTRACKS_SEARCH_ALIASES_GENERATED_PATH=./data/owntracks/search_aliases.generated.json
OWNTRACKS_SEARCH_ALIASES_LOCAL_PATH=./data/owntracks/search_aliases.local.json
OWNTRACKS_TIMEZONE=Asia/Kolkata
# Hide raw visualization points around home geofences, while preserving the raw
# OwnTracks log and stop review data.
OWNTRACKS_HOME_FILTER_ENABLED=false
OWNTRACKS_HOME_REGION_NAMES=Home
OWNTRACKS_HOME_FILTER_RADIUS_METERS=150
# Hide route jitter around any detected stop/geofence in daily visualizations.
# Heatmaps keep stop points so "where time was spent" remains accurate.
OWNTRACKS_STOP_JITTER_FILTER_ENABLED=false
OWNTRACKS_STOP_JITTER_RADIUS_METERS=150
OWNTRACKS_STOP_JITTER_MIN_DWELL_MINUTES=10
OWNTRACKS_STOP_JITTER_INCLUDE_GEOFENCES=true
OWNTRACKS_STOP_JITTER_INCLUDE_CANDIDATE_STOPS=true
# file sends the HTML as a Telegram attachment. hosted sends a local HTTP URL
# served by the bot's HTTP intake server.
OWNTRACKS_MAP_DELIVERY=file
# Required for hosted mode on iOS unless HTTP_INTAKE_HOST is directly reachable.
# Example: http://192.168.1.50:8787
OWNTRACKS_MAP_BASE_URL=
